<icecast>
    <location>Brazil</location>
    <admin>sistematico@gmail.com</admin>

    <limits>
        <clients>5000</clients>
        <sources>10</sources>
        <queue-size>1048576</queue-size>
        <client-timeout>60</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>30</source-timeout>
        <burst-on-connect>1</burst-on-connect>
        <burst-size>131072</burst-size>
    </limits>

    <authentication>
        <source-password>hackme</source-password>
        <relay-password>hackme</relay-password>
        <admin-user>admin</admin-user>
        <admin-password>hackmeagain</admin-password>
    </authentication>

    <directory>
        <yp-url-timeout>15</yp-url-timeout>
        <yp-url>http://dir.xiph.org/cgi-bin/yp-cgi</yp-url>
    </directory>

    <hostname>somdomato.com</hostname>

    <mount type="default">
        <charset>UTF-8</charset>
    </mount>

    <!-- Mount Geral - Aceita pedidos -->
    <mount type="normal">
        <mount-name>/geral</mount-name>
        <charset>UTF-8</charset>
        <stream-name>Som do Mato - Geral</stream-name>
        <stream-description>Rádio geral com pedidos</stream-description>
        <stream-url>https://somdomato.com</stream-url>
        <genre>Sertanejo</genre>
        <bitrate>128</bitrate>
        <public>1</public>
    </mount>

    <!-- Mount Gaúcha -->
    <mount type="normal">
        <mount-name>/gaucha</mount-name>
        <charset>UTF-8</charset>
        <stream-name>Som do Mato - Gaúcha</stream-name>
        <stream-description>Sertanejo gaúcho</stream-description>
        <stream-url>https://somdomato.com</stream-url>
        <genre>Gaúcha</genre>
        <bitrate>128</bitrate>
        <public>1</public>
    </mount>

    <!-- Mount Modão -->
    <mount type="normal">
        <mount-name>/modao</mount-name>
        <charset>UTF-8</charset>
        <stream-name>Som do Mato - Modão</stream-name>
        <stream-description>Modão tradicional</stream-description>
        <stream-url>https://somdomato.com</stream-url>
        <genre>Modão</genre>
        <bitrate>128</bitrate>
        <public>1</public>
    </mount>

    <!-- Mount Arrocha -->
    <mount type="normal">
        <mount-name>/arrocha</mount-name>
        <charset>UTF-8</charset>
        <stream-name>Som do Mato - Arrocha</stream-name>
        <stream-description>Arrocha e romantic</stream-description>
        <stream-url>https://somdomato.com</stream-url>
        <genre>Arrocha</genre>
        <bitrate>128</bitrate>
        <public>1</public>
    </mount>

    <!-- Mount Romântico -->
    <mount type="normal">
        <mount-name>/romantico</mount-name>
        <charset>UTF-8</charset>
        <stream-name>Som do Mato - Romântico</stream-name>
        <stream-description>Músicas românticas</stream-description>
        <stream-url>https://somdomato.com</stream-url>
        <genre>Romântico</genre>
        <bitrate>128</bitrate>
        <public>1</public>
    </mount>

    <listen-socket>
        <port>8000</port>
    </listen-socket>

    <listen-socket>
        <port>8443</port>
        <ssl>1</ssl>
    </listen-socket>

    <http-headers>
        <header name="Access-Control-Allow-Origin" value="*" />
    </http-headers>

    <fileserve>1</fileserve>

    <paths>
        <basedir>/usr/share/icecast2</basedir>
        <logdir>/var/log/icecast2</logdir>
        <webroot>/usr/share/icecast2/web</webroot>
        <adminroot>/usr/share/icecast2/admin</adminroot>
	    <pidfile>/run/icecast2-somdomato.pid</pidfile>
        <alias source="/" destination="/status.xsl"/>
        <alias source="/json" destination="/status-json.xsl"/>
        <ssl-certificate>/usr/share/icecast2/icecast-somdomato.pem</ssl-certificate>
    </paths>

    <logging>
        <accesslog>access.log</accesslog>
        <errorlog>error.log</errorlog>
        <loglevel>1</loglevel> <!-- 4 Debug, 3 Info, 2 Warn, 1 Error -->
        <logsize>10000</logsize> <!-- Max size of a logfile -->
    </logging>

    <security>
        <chroot>0</chroot>
    </security>
</icecast>
